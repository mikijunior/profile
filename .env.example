# Required for AI chat.
OPENROUTER_API_KEY=

# Optional local friction layer, required in production with the current API guard.
# Generate with: openssl rand -hex 32
# Both values must be identical.
CHAT_REQUEST_TOKEN=
NEXT_PUBLIC_CHAT_REQUEST_TOKEN=

# Required in production for canonical URLs, sitemap, robots, OpenRouter referer,
# and API origin validation.
SITE_URL=
